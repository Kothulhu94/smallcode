// SmallCode — Deterministic Tool Router
// Compiles to pure JS classifier (no LLM needed)
// Routes user messages to tool categories based on intent signals
//
// Categories: read | write | search | run | plan | web | respond
//
// This replaces the TinyRouter model for tool classification.
// Zero tokens, zero latency, 100% deterministic.

system ToolRouter {
  domain: deterministic_classifier

  // ═══════════════════════════════════════════════════════════════════════════
  // CATEGORY DEFINITIONS — weighted signal matchers
  // ═══════════════════════════════════════════════════════════════════════════

  category read {
    weight: 1.0
    signals: [
      // Direct read intents
      { pattern: "read|show|cat|display|print|view|open|look at|check|see|inspect", weight: 3.0 },
      { pattern: "what's in|what is in|contents of|content of", weight: 3.0 },
      { pattern: "file|\.ts|\.js|\.py|\.rs|\.go|\.java|\.c|\.cpp|\.md", weight: 1.5 },
      // Negatives (reduce score if these present)
      { pattern: "fix|change|update|modify|add|remove|delete|create|write", weight: -2.0 },
      { pattern: "run|execute|test|build|install", weight: -1.5 }
    ]
    min_confidence: 0.4
  }

  category write {
    weight: 1.0
    signals: [
      { pattern: "fix|change|update|modify|edit|refactor|rename|replace", weight: 3.0 },
      { pattern: "add|insert|append|prepend|implement|create|write|make", weight: 2.5 },
      { pattern: "remove|delete|strip|clean up|drop", weight: 2.0 },
      { pattern: "bug|error|typo|issue|broken|wrong|incorrect", weight: 2.0 },
      { pattern: "file|function|class|method|variable|import|export", weight: 1.0 },
      // Negatives
      { pattern: "explain|what|why|how does|tell me", weight: -2.0 },
      { pattern: "search|find|grep|look for", weight: -1.5 }
    ]
    min_confidence: 0.3
  }

  category search {
    weight: 1.0
    signals: [
      { pattern: "find|search|grep|look for|locate|where is|where are", weight: 3.0 },
      { pattern: "all uses of|all references|who calls|who uses|imports of", weight: 3.0 },
      { pattern: "pattern|regex|match|occurrences", weight: 2.0 },
      { pattern: "across|everywhere|all files|codebase|project", weight: 1.5 },
      // Negatives
      { pattern: "fix|change|update|create|write", weight: -2.0 }
    ]
    min_confidence: 0.4
  }

  category run {
    weight: 1.0
    signals: [
      { pattern: "run|execute|start|launch|invoke|call", weight: 3.0 },
      { pattern: "test|tests|spec|specs|jest|pytest|mocha|vitest", weight: 3.0 },
      { pattern: "build|compile|make|bundle|webpack|tsc|cargo", weight: 2.5 },
      { pattern: "install|npm|pip|yarn|pnpm|apt|brew", weight: 2.5 },
      { pattern: "lint|format|prettier|eslint|black|ruff", weight: 2.0 },
      { pattern: "git|commit|push|pull|merge|branch|checkout|diff|status", weight: 2.0 },
      { pattern: "deploy|docker|k8s|kubernetes|terraform", weight: 2.0 },
      // Negatives
      { pattern: "explain|what|why|how does", weight: -1.5 }
    ]
    min_confidence: 0.3
  }

  category plan {
    weight: 1.0
    signals: [
      { pattern: "implement|build|create|design|architect", weight: 2.0 },
      { pattern: "full|complete|entire|whole|end.to.end|e2e", weight: 2.5 },
      { pattern: "system|module|feature|service|api|app|application", weight: 1.5 },
      { pattern: "step by step|plan|break down|decompose|how should i", weight: 3.0 },
      { pattern: "multiple files|several files|across files|refactor all", weight: 2.0 },
      // Complexity signal: long messages often need planning
      { pattern: "__long_message__", weight: 2.0 },
      // Negatives
      { pattern: "show|read|display|cat", weight: -2.0 }
    ]
    min_confidence: 0.5
  }

  category web {
    weight: 1.0
    signals: [
      { pattern: "search the web|google|look up online|internet", weight: 3.0 },
      { pattern: "latest version|current version|newest|recent", weight: 2.0 },
      { pattern: "documentation|docs|api reference|npm page|pypi", weight: 2.0 },
      { pattern: "url|website|link|http|https", weight: 2.5 },
      { pattern: "download|fetch from|get from", weight: 1.5 }
    ]
    min_confidence: 0.5
  }

  category respond {
    weight: 0.8
    signals: [
      { pattern: "explain|what is|what are|how does|why|tell me|describe", weight: 3.0 },
      { pattern: "difference between|compare|vs|versus", weight: 2.5 },
      { pattern: "help|guide|tutorial|example|show me how", weight: 2.0 },
      { pattern: "opinion|think|recommend|suggest|best practice", weight: 2.0 },
      { pattern: "thanks|thank you|ok|sure|yes|no|got it", weight: 3.0 }
    ]
    min_confidence: 0.3
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // ROUTING POLICY
  // ═══════════════════════════════════════════════════════════════════════════

  policy routing {
    // If no category exceeds min_confidence, default to write (most common intent)
    fallback: write
    // If message is under 10 chars, default to respond (greeting/ack)
    short_message_threshold: 10
    short_message_default: respond
    // If message is over 200 chars, boost plan category
    long_message_threshold: 200
    // Tie-breaking: prefer action over observation
    priority_order: [write, run, search, plan, read, web, respond]
  }
}
