// SmallCode Bounded Agent Loops — MarrowScript declaration
// Replaces hand-rolled improvement loop with compiled retry+validate pattern.
//
// Pattern: generate → validate → revise until passes or max N iterations.
// Used for: write_file → node --check → fix errors → repeat

system SmallCodeLoops {
  domain: cognitive_scaffold

  model Worker {
    provider: openai_compat
    endpoint: "${SMALLCODE_BASE_URL}"
    name: "${SMALLCODE_MODEL}"
    context_window: 128000
    max_output: 8192
    temperature: 0.1
    cost_class: small
    latency_class: medium
  }

  extension_point tmpl_fix_errors(file_path: string, errors: string, previous_attempts: string) {
    returns: string
    stable: true
  }

  prompt fix_errors(file_path: string, errors: string, previous_attempts: string) {
    model: Worker
    template: "extension_point:tmpl_fix_errors"
    returns: string
    timeout: 60s
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 500ms }
  }

  capability validate_file(path: string) {
    cognition: self_critique using {
      output: path,
      criteria: ["compiles_without_errors", "no_placeholders", "no_truncation"]
    }
    returns: string
    sync: eventual
    idempotent: true
  }

  capability fix_code(path: string, errors: string) {
    cognition: repair_with_diff using {
      source: path,
      issues: errors,
      strategy: "minimal_patch"
    }
    returns: string
    sync: eventual
  }

  flow improvement_loop {
    step validate: validate_file(ctx.file_path)
      compensate: rollback_file(ctx.file_path)
    step fix: fix_code(ctx.file_path, validate.output)
      compensate: rollback_file(ctx.file_path)
  }

  policy loop_limits {
    rate_limit: 30 per 1m
    audit: true
  }
}
